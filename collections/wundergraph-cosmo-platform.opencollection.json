      },
      "items": [
        {
          "info": {
            "name": "WunderGraph List federated graphs",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://cosmo-cp.wundergraph.com/v1/federated-graphs",
            "params": [
              {
                "name": "namespace",
                "value": "",
                "type": "query",
                "description": "Filter by namespace name."
              },
              {
                "name": "limit",
                "value": "",
                "type": "query",
                "description": "Maximum number of results to return."
              },
              {
                "name": "offset",
                "value": "",
                "type": "query",
                "description": "Number of results to skip."
              }
            ],
            "auth": {
              "type": "apikey",
              "key": "Authorization",
              "value": "{{Authorization}}",
              "placement": "header"
            }
          },
          "docs": "Lists all federated graphs in the organization, optionally filtered by namespace. Federated graphs represent the composed supergraph made up of multiple subgraphs."
        },
        {
          "info": {
            "name": "WunderGraph Create a federated graph",
            "type": "http"
