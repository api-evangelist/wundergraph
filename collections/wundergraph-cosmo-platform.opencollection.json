              {
                "name": "name",
                "value": "",
                "type": "path",
                "description": "The name of the federated graph to update."
              }
            ],
            "body": {
              "type": "json",
              "data": "{}"
            },
            "auth": {
              "type": "apikey",
              "key": "Authorization",
              "value": "{{Authorization}}",
              "placement": "header"
