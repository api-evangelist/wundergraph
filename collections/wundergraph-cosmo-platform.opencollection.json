            "name": "WunderGraph Delete a federated graph",
            "type": "http"
          },
          "http": {
            "method": "DELETE",
            "url": "https://cosmo-cp.wundergraph.com/v1/federated-graphs/:name",
            "params": [
              {
                "name": "name",
                "value": "",
                "type": "path",
                "description": "The name of the federated graph to delete."
              },
              {
                "name": "namespace",
                "value": "",
                "type": "query",
